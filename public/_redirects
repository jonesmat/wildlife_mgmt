# Cloudflare Pages rewrites (200 = rewrite, not redirect).
#
# Pages serves clean URLs natively (/log -> log.html) and 308-redirects
# /log.html back to /log, so rewriting TO an .html target causes a redirect
# loop. Only the dynamic-segment routes need rules, and their targets must be
# the extensionless paths.
/report/*       /report        200
/report-print/* /report-print  200
